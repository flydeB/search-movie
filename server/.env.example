# OMDb API Key（申请地址：https://www.omdbapi.com/apikey.aspx，邮箱即可申请免费Key）
OMDB_API_KEY=your_omdb_api_key_here

# TMDB API Key（申请地址：https://www.themoviedb.org/settings/api）
TMDB_API_KEY=your_tmdb_api_key_here

# TMDB 代理地址（可选：国内访问 TMDB 不稳定时使用 Vercel 代理）
# TMDB_BASE_URL=https://your-app.vercel.app/3
# TMDB_IMAGE_URL=https://your-app.vercel.app/image

# 后端端口
PORT=3001
